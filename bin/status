#!/bin/sh

do_work()
{

	RC=$(salt-ssh "${THIS_ANIMAL}" --out json -r "[ -d ${THIS_ANIMAL} ] && printf \"1\" || printf \"0\"" | sed -n '/{/,$p' | jq -r ".${THIS_ANIMAL}.stdout")
	if [ "${RC}" = "1" ]; then
		STATLINE="${STATLINE} client-downloaded"
	elif [ "${RC}" = "0" ]; then
		STATLINE="${STATLINE} client-missing"
	else
		STATLINE="${STATLINE} client-unknown"
	fi

	RC=$(salt-ssh "${THIS_ANIMAL}" --out json -r "[ -f ${THIS_ANIMAL}/build-farm.conf ] && printf \"1\" || printf \"0\"" | sed -n '/{/,$p' | jq -r ".${THIS_ANIMAL}.stdout")
	if [ "${RC}" = "1" ]; then
		STATLINE="${STATLINE} client-configured"

		RC=$(salt-ssh "${THIS_ANIMAL}" --out json -r "grep VERSION ${THIS_ANIMAL}/build-farm.conf | sed 's/[^0-9]//g'" | sed -n '/{/,$p' | jq -r ".${THIS_ANIMAL}.stdout")
		STATLINE="${STATLINE} client-version-${RC}"
	elif [ "${RC}" = "0" ]; then
		STATLINE="${STATLINE} client-not-configured client-version-unknown"
	else
		STATLINE="${STATLINE} client-unknown client-version-unknown"
	fi

	RC=$(salt-ssh "${THIS_ANIMAL}" --out json -r "crontab -l | grep -q '#Ansible: ${THIS_ANIMAL}' && printf \"1\" || printf \"0\"" | sed -n '/{/,$p' | jq -r ".${THIS_ANIMAL}.stdout")
	if [ "${RC}" = "1" ]; then
		STATLINE="${STATLINE} cron-enabled"
	elif [ "${RC}" = "0" ]; then
		STATLINE="${STATLINE} cron-disabled"
	else
		STATLINE="${STATLINE} cron-unknown"
	fi

	return 0
}

ERROR=""
NOOP=""
SUCCESS=""
UNEXPECTED=""

for THIS_ANIMAL in $(yq -r '. | keys[]' salt/roster); do
	if [ ! "${ANIMALS}" = "" ] && \
			! echo "${ANIMALS}" | grep -Eq "(^|,)${THIS_ANIMAL}(,|$)"; then
		continue
	fi

	STATLINE=""
	do_work
	echo "${THIS_ANIMAL}: ${STATLINE}"

	STATUS=${?}
	case "${STATUS}" in
	0) SUCCESS="${SUCCESS} ${THIS_ANIMAL}" ;;
	1) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	2) NOOP="${NOOP} ${THIS_ANIMAL}" ;;
	3) ERROR="${ERROR} ${THIS_ANIMAL}" ;;
	*) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	esac
done

echo "SUCCESS"
for ANIMAL in ${SUCCESS}; do
	echo "  ${ANIMAL}"
done

echo "NOTHING TO DO"
for ANIMAL in ${NOOP}; do
	echo "  ${ANIMAL}"
done

echo "ERROR"
for ANIMAL in ${ERROR}; do
	echo "  ${ANIMAL}"
done

echo "UNKNOWN ISSUE"
for ANIMAL in ${UNEXPECTED}; do
	echo "  ${ANIMAL}"
done
