#!/bin/sh

do_work()
{
	RC=$(salt-ssh "${THIS_ANIMAL}" --out json -r "[ -d ${THIS_ANIMAL} ] && printf \"1\" || printf \"0\"" | sed -n '/{/,$p' | jq -r ".${THIS_ANIMAL}.stdout")
	if [ "${RC}" = "0" ]; then
		echo "Build farm client is not downloaded for this ${THIS_ANIMAL}."
		return 2
	elif [ ! "${RC}" = "1" ]; then
		echo "Unknown issue with ${THIS_ANIMAL}."
		return 1
	fi

	HOUR=$(yq -r ".${THIS_ANIMAL}.hour" salt/roster)
	if [ "${HOUR}" = "" ]; then
		echo "You must define an hour in the roster file!"
		return 3
	fi

	salt-ssh "${THIS_ANIMAL}" -r "crontab -l | grep -q '#Ansible: ${THIS_ANIMAL}' && \
(crontab -l | sed '/#Ansible: ${THIS_ANIMAL}/{n;c 8 ${HOUR} * * * cd '\${HOME}'/${THIS_ANIMAL} && perl ./run_branches.pl --run-all
}' | crontab -) || \
(crontab -l; echo '#Ansible: ${THIS_ANIMAL}'; echo '8 ${HOUR} * * * cd '\${HOME}'/${THIS_ANIMAL} && perl ./run_branches.pl --run-all') | crontab -"

	return 0
}

ERROR=""
NOOP=""
SUCCESS=""
UNEXPECTED=""

for THIS_ANIMAL in $(yq -r '. | keys[]' salt/roster); do
	if [ ! "${ANIMALS}" = "" ] && \
			! echo "${ANIMALS}" | grep -Eq "(^|,)${THIS_ANIMAL}(,|$)"; then
		continue
	fi

	echo "ANIMAL: ${THIS_ANIMAL}"

	do_work
	STATUS=${?}
	case "${STATUS}" in
	0) SUCCESS="${SUCCESS} ${THIS_ANIMAL}" ;;
	1) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	2) NOOP="${NOOP} ${THIS_ANIMAL}" ;;
	3) ERROR="${ERROR} ${THIS_ANIMAL}" ;;
	*) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	esac
done

echo "SUCCESS"
for ANIMAL in ${SUCCESS}; do
	echo "  ${ANIMAL}"
done

echo "NOTHING TO DO"
for ANIMAL in ${NOOP}; do
	echo "  ${ANIMAL}"
done

echo "ERROR"
for ANIMAL in ${ERROR}; do
	echo "  ${ANIMAL}"
done

echo "UNKNOWN ISSUE"
for ANIMAL in ${UNEXPECTED}; do
	echo "  ${ANIMAL}"
done
