#!/bin/sh

do_work()
{
	OSRELEASE=$(salt-ssh "${THIS_ANIMAL}" --out json -r 'cat /etc/os-release' | jq -r ".${THIS_ANIMAL}.stdout")
	NAME=$(printf "%s" "${OSRELEASE}" | grep '^NAME=' | cut -d= -f2 | tr -d '"')
	VERSION=$(printf "%s" "${OSRELEASE}" | grep '^VERSION=' | cut -d= -f2 | tr -d '"')
	ARCH=$(salt-ssh "${THIS_ANIMAL}" --out json -r 'uname -m' | jq -r ".${THIS_ANIMAL}.stdout")
	GCC=$(salt-ssh "${THIS_ANIMAL}" --out json -r 'gcc --version | head -n 1' | jq -r ".${THIS_ANIMAL}.stdout")
	CLANG=$(salt-ssh "${THIS_ANIMAL}" --out json -r 'clang --version | head -n 1' | jq -r ".${THIS_ANIMAL}.stdout")

	echo "${THIS_ANIMAL} | ${NAME} | ${ARCH} | ${VERSION} | ${GCC} | ${CLANG}"

	return 0
}

ERROR=""
NOOP=""
SUCCESS=""
UNEXPECTED=""

for THIS_ANIMAL in $(yq -r '. | keys[]' salt/roster); do
	if [ ! "${ANIMALS}" = "" ] && \
			! echo "${ANIMALS}" | grep -Eq "(^|,)${THIS_ANIMAL}(,|$)"; then
		continue
	fi

	do_work
	STATUS=${?}
	case "${STATUS}" in
	0) SUCCESS="${SUCCESS} ${THIS_ANIMAL}" ;;
	1) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	2) NOOP="${NOOP} ${THIS_ANIMAL}" ;;
	3) ERROR="${ERROR} ${THIS_ANIMAL}" ;;
	*) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	esac
done

echo "SUCCESS"
for ANIMAL in ${SUCCESS}; do
	echo "  ${ANIMAL}"
done

echo "NOTHING TO DO"
for ANIMAL in ${NOOP}; do
	echo "  ${ANIMAL}"
done

echo "ERROR"
for ANIMAL in ${ERROR}; do
	echo "  ${ANIMAL}"
done

echo "UNKNOWN ISSUE"
for ANIMAL in ${UNEXPECTED}; do
	echo "  ${ANIMAL}"
done
