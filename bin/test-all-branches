#!/bin/sh

do_work()
{
	salt-ssh "${THIS_ANIMAL}" -r "cd ${THIS_ANIMAL} && perl run_branches.pl --test --force --run-all" || return 3
	return 0
}

ERROR=""
NOOP=""
SUCCESS=""
UNEXPECTED=""

for THIS_ANIMAL in $(yq -r '. | keys[]' salt/roster); do
	if [ ! "${ANIMALS}" = "" ] && \
			! echo "${ANIMALS}" | grep -Eq "(^|,)${THIS_ANIMAL}(,|$)"; then
		continue
	fi

	echo "ANIMAL: ${THIS_ANIMAL}"

	do_work
	STATUS=${?}
	case "${STATUS}" in
	0) SUCCESS="${SUCCESS} ${THIS_ANIMAL}" ;;
	1) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	2) NOOP="${NOOP} ${THIS_ANIMAL}" ;;
	3) ERROR="${ERROR} ${THIS_ANIMAL}" ;;
	*) UNEXPECTED="${UNEXPECTED} ${THIS_ANIMAL}" ;;
	esac
done

echo "SUCCESS"
for ANIMAL in ${SUCCESS}; do
	echo "  ${ANIMAL}"
done

echo "NOTHING TO DO"
for ANIMAL in ${NOOP}; do
	echo "  ${ANIMAL}"
done

echo "ERROR"
for ANIMAL in ${ERROR}; do
	echo "  ${ANIMAL}"
done

echo "UNKNOWN ISSUE"
for ANIMAL in ${UNEXPECTED}; do
	echo "  ${ANIMAL}"
done
